#!/usr/bin/env bash
set -euo pipefail

USER_NAME="$(id -un)"
SHARE_DIR="${HOME}/.local/share/claude-box"

# Derive a tag-safe slug from an image reference (e.g. "myrepo/dev:1.0" → "myrepo-dev-1-0")
image_slug() {
    printf '%s' "$1" | tr -cs 'a-zA-Z0-9' '-' | sed 's/^-//;s/-$//'
}

usage() {
    cat <<EOF
Usage: claude-box [OPTIONS] [COMMAND] [-- CLAUDE_ARGS...]

Launch Claude Code in an isolated container, mounting the current directory
(or the directory given by -C) as the workspace.

The container image is built automatically on first run.
~/.claude.json and ~/.claude are mounted so Claude retains its
configuration and session data across invocations.

Commands:
  init    Write .config/claude-box.conf in the current directory with the
          current effective configuration (from ~/.config/claude-box.conf
          and CLI flags). Errors if the file already exists.

Options:
  -C, --directory DIR        Change to DIR before doing anything
  -b, --base-image IMAGE     Base image to layer Claude Code on top of
                             (default: node:lts-slim). Must be
                             Debian/Ubuntu (apt-get) or RHEL/Fedora/UBI (dnf)
                             compatible. Each distinct base image gets its own
                             cached image.
  --rebuild                  Rebuild the container image from scratch (--no-cache)
  -h, --help                 Show this help message

Any arguments after -- are passed directly to the claude command inside
the container (e.g. claude-box -- --model claude-opus-4-6).
EOF
    exit "${1:-0}"
}

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
BASE_IMAGE="node:lts-slim"

# shellcheck source=/dev/null
[[ -f "${HOME}/.config/claude-box.conf" ]] && source "${HOME}/.config/claude-box.conf"

# ---------------------------------------------------------------------------
# Argument parsing
# -C/--directory is handled immediately so the local config is loaded from
# the right place. Other config-affecting flags are saved as CLI_* overrides
# and applied after the local config is sourced.
# ---------------------------------------------------------------------------
REBUILD=false
COMMAND=""
CLAUDE_ARGS=()
CLI_BASE_IMAGE=""

while [[ $# -gt 0 ]]; do
    case $1 in
        -C|--directory)
            if [[ -z "${2:-}" ]]; then
                echo "claude-box: --directory requires an argument" >&2
                usage 1
            fi
            cd "$2"
            shift 2
            ;;
        --base-image|-b)
            if [[ -z "${2:-}" ]]; then
                echo "claude-box: --base-image requires an argument" >&2
                usage 1
            fi
            CLI_BASE_IMAGE="$2"
            shift 2
            ;;
        --rebuild)
            REBUILD=true
            shift
            ;;
        -h|--help)
            usage 0
            ;;
        --)
            shift
            CLAUDE_ARGS=("$@")
            break
            ;;
        -*)
            echo "claude-box: unknown option: $1" >&2
            usage 1
            ;;
        *)
            if [[ -n "$COMMAND" ]]; then
                echo "claude-box: unexpected argument: $1" >&2
                usage 1
            fi
            COMMAND="$1"
            shift
            ;;
    esac
done

# shellcheck source=/dev/null
[[ -f ".config/claude-box.conf" ]] && source ".config/claude-box.conf"

[[ -n "$CLI_BASE_IMAGE" ]] && BASE_IMAGE="$CLI_BASE_IMAGE"

# ---------------------------------------------------------------------------
# init command
# ---------------------------------------------------------------------------
if [[ "$COMMAND" == "init" ]]; then
    if [[ ${#CLAUDE_ARGS[@]} -gt 0 ]]; then
        echo "claude-box: 'init' does not accept -- arguments" >&2
        usage 1
    fi
    CONF_FILE=".config/claude-box.conf"
    if [[ -f "$CONF_FILE" ]]; then
        echo "claude-box: '${PWD}/${CONF_FILE}' already exists; delete it to reinitialize" >&2
        exit 1
    fi
    mkdir -p .config
    cat > "$CONF_FILE" <<EOF
# claude-box configuration
# Sourced before CLI argument parsing; CLI flags take precedence.

# Base image to layer Claude Code on top of.
# Must be Debian/Ubuntu (apt-get) or RHEL/Fedora/UBI (dnf) compatible.
# Each distinct base image gets its own cached container image.
BASE_IMAGE="${BASE_IMAGE}"
EOF
    echo "claude-box: created ${PWD}/${CONF_FILE}" >&2
    exit 0
fi

if [[ -n "$COMMAND" ]]; then
    echo "claude-box: unknown command: $COMMAND" >&2
    usage 1
fi

IMAGE_NAME="claude-box:uid-$(id -u)-$(image_slug "$BASE_IMAGE")"

# ---------------------------------------------------------------------------
# Image build
# ---------------------------------------------------------------------------
build_image() {
    local -a extra_args=()
    if [[ "$REBUILD" == "true" ]]; then
        extra_args+=("--no-cache")
    fi

    echo "claude-box: building image ${IMAGE_NAME} ..." >&2
    podman build \
        "${extra_args[@]}" \
        --build-arg BASE_IMAGE="$BASE_IMAGE" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        --build-arg USER_NAME="$USER_NAME" \
        -t "$IMAGE_NAME" \
        "$SHARE_DIR"
}

if [[ "$REBUILD" == "true" ]]; then
    build_image
elif ! podman image exists "$IMAGE_NAME" 2>/dev/null; then
    build_image
fi

# ---------------------------------------------------------------------------
# Ensure Claude config paths exist on the host before mounting.
# Mounting a non-existent file causes podman to create a directory instead.
# ---------------------------------------------------------------------------
if [[ ! -f "${HOME}/.claude.json" ]]; then
    echo '{}' > "${HOME}/.claude.json"
fi
mkdir -p "${HOME}/.claude"

# ---------------------------------------------------------------------------
# Git config mounts (read-only)
# System gitconfig (/etc/gitconfig) is not relabelled (:z omitted) to avoid
# permanently changing SELinux labels on shared system files.
# ---------------------------------------------------------------------------
GIT_CONFIG_MOUNTS=()
[[ -f "${HOME}/.gitconfig" ]] && \
    GIT_CONFIG_MOUNTS+=(-v "${HOME}/.gitconfig:/home/${USER_NAME}/.gitconfig:ro,z")
[[ -d "${HOME}/.config/git" ]] && \
    GIT_CONFIG_MOUNTS+=(-v "${HOME}/.config/git:/home/${USER_NAME}/.config/git:ro,z")
[[ -f "/etc/gitconfig" ]] && \
    GIT_CONFIG_MOUNTS+=(-v "/etc/gitconfig:/etc/gitconfig:ro")

# ---------------------------------------------------------------------------
# Environment variables forwarded to the container
# ---------------------------------------------------------------------------
FORWARDED_ENV=()
[[ -n "${EDITOR:-}" ]] && FORWARDED_ENV+=(--env "EDITOR=${EDITOR}")

# ---------------------------------------------------------------------------
# Run
#
# --userns=keep-id   maps the host UID:GID to the same UID:GID inside the
#                    container, which is what the Dockerfile user was built
#                    with. This avoids root inside the container (required
#                    by --dangerously-skip-permissions) and ensures bind-
#                    mounted files are readable/writable without chown.
#
# :z on each volume  adds the 'container_file_t' SELinux label so the
#                    container process is allowed to access the files.
#                    Lower-case :z marks the label as shared (safe for home
#                    directory contents that may be accessed by other
#                    confined processes). Use :Z (private) only on
#                    directories that are exclusively owned by this
#                    container.
# ---------------------------------------------------------------------------
exec podman run \
    --rm \
    --interactive \
    --tty \
    --userns=keep-id \
    -v "${PWD}:/workspace:z" \
    -v "${HOME}/.claude.json:/home/${USER_NAME}/.claude.json:z" \
    -v "${HOME}/.claude:/home/${USER_NAME}/.claude:z" \
    "${GIT_CONFIG_MOUNTS[@]+"${GIT_CONFIG_MOUNTS[@]}"}" \
    "${FORWARDED_ENV[@]+"${FORWARDED_ENV[@]}"}" \
    "$IMAGE_NAME" \
    "${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}"
