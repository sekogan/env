#!/usr/bin/env bash
set -euo pipefail

USER_NAME="$(id -un)"
SHARE_DIR="${HOME}/.local/share/claude-box"

# Derive a tag-safe slug from an image reference (e.g. "myrepo/dev:1.0" → "myrepo-dev-1-0")
image_slug() {
    printf '%s' "$1" | tr -cs 'a-zA-Z0-9' '-' | sed 's/^-//;s/-$//'
}

usage() {
    cat <<EOF
Usage: claude-box [OPTIONS] [-- CLAUDE_ARGS...]

Launch Claude Code in an isolated container, mounting the current directory
as the workspace.

The container image is built automatically on first run.
~/.claude.json and ~/.claude are mounted so Claude retains its
configuration and session data across invocations.

Options:
  -b, --base-image IMAGE     Base image to layer Claude Code on top of
                             (default: node:lts-slim). Must be
                             Debian/Ubuntu (apt-get) or RHEL/Fedora/UBI (dnf)
                             compatible. Each distinct base image gets its own
                             cached image.
  --rebuild                  Rebuild the container image from scratch (--no-cache)
  -h, --help                 Show this help message

Any arguments after -- are passed directly to the claude command inside
the container (e.g. claude-box -- --model claude-opus-4-6).
EOF
    exit "${1:-0}"
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
REBUILD=false
BASE_IMAGE="node:lts-slim"
CLAUDE_ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        --base-image|-b)
            if [[ -z "${2:-}" ]]; then
                echo "claude-box: --base-image requires an argument" >&2
                usage 1
            fi
            BASE_IMAGE="$2"
            shift 2
            ;;
        --rebuild)
            REBUILD=true
            shift
            ;;
        -h|--help)
            usage 0
            ;;
        --)
            shift
            CLAUDE_ARGS=("$@")
            break
            ;;
        *)
            echo "claude-box: unknown option: $1" >&2
            usage 1
            ;;
    esac
done

IMAGE_NAME="claude-box:uid-$(id -u)-$(image_slug "$BASE_IMAGE")"

# ---------------------------------------------------------------------------
# Image build
# ---------------------------------------------------------------------------
build_image() {
    local -a extra_args=()
    if [[ "$REBUILD" == "true" ]]; then
        extra_args+=("--no-cache")
    fi

    echo "claude-box: building image ${IMAGE_NAME} ..." >&2
    podman build \
        "${extra_args[@]}" \
        --build-arg BASE_IMAGE="$BASE_IMAGE" \
        --build-arg USER_UID="$(id -u)" \
        --build-arg USER_GID="$(id -g)" \
        --build-arg USER_NAME="$USER_NAME" \
        -t "$IMAGE_NAME" \
        "$SHARE_DIR"
}

if [[ "$REBUILD" == "true" ]]; then
    build_image
elif ! podman image exists "$IMAGE_NAME" 2>/dev/null; then
    build_image
fi

# ---------------------------------------------------------------------------
# Ensure Claude config paths exist on the host before mounting.
# Mounting a non-existent file causes podman to create a directory instead.
# ---------------------------------------------------------------------------
if [[ ! -f "${HOME}/.claude.json" ]]; then
    echo '{}' > "${HOME}/.claude.json"
fi
mkdir -p "${HOME}/.claude"

# ---------------------------------------------------------------------------
# Run
#
# --userns=keep-id   maps the host UID:GID to the same UID:GID inside the
#                    container, which is what the Dockerfile user was built
#                    with. This avoids root inside the container (required
#                    by --dangerously-skip-permissions) and ensures bind-
#                    mounted files are readable/writable without chown.
#
# :z on each volume  adds the 'container_file_t' SELinux label so the
#                    container process is allowed to access the files.
#                    Lower-case :z marks the label as shared (safe for home
#                    directory contents that may be accessed by other
#                    confined processes). Use :Z (private) only on
#                    directories that are exclusively owned by this
#                    container.
# ---------------------------------------------------------------------------
exec podman run \
    --rm \
    --interactive \
    --tty \
    --userns=keep-id \
    -v "${PWD}:/workspace:z" \
    -v "${HOME}/.claude.json:/home/${USER_NAME}/.claude.json:z" \
    -v "${HOME}/.claude:/home/${USER_NAME}/.claude:z" \
    "$IMAGE_NAME" \
    "${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}"
